---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Verify once. Pass everywhere.' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} — Hyprlane</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-bg-base text-text-primary min-h-screen">
    <nav class="fixed top-0 left-0 right-0 z-50 bg-bg-base/80 backdrop-blur-sm border-b border-border-subtle">
      <div class="max-w-[1120px] mx-auto px-6 h-16 flex items-center justify-between">
        <a href={base} class="font-display text-xl font-semibold tracking-tight text-text-primary hover:text-accent transition-colors">
          Hyprlane
        </a>
        <div class="flex items-center gap-6">
          <a href="https://docs.hyprlane.app" class="text-sm text-text-secondary hover:text-accent transition-colors">Docs</a>
          <a href={`${base}dashboard/`} class="btn-primary text-sm py-2 px-4">Login</a>
        </div>
      </div>
    </nav>

    <main class="pt-16">
      <slot />
    </main>

    <footer class="border-t border-border-subtle mt-32">
      <div class="max-w-[1120px] mx-auto px-6 py-12 flex flex-col sm:flex-row items-center justify-between gap-4">
        <p class="text-sm text-text-muted">
          Built by <a href="https://github.com/TheCinderProject" class="text-text-secondary hover:text-accent transition-colors">The Cinder Project</a>
        </p>
        <div class="flex items-center gap-6">
          <a href="https://github.com/TheCinderProject/hyprlane-bot" class="text-sm text-text-muted hover:text-accent transition-colors">Bot</a>
          <a href="https://github.com/TheCinderProject/hyprlane-api" class="text-sm text-text-muted hover:text-accent transition-colors">API</a>
          <a href="https://github.com/TheCinderProject/hyprlane-web" class="text-sm text-text-muted hover:text-accent transition-colors">Web</a>
        </div>
      </div>
    </footer>
  </body>
</html>
