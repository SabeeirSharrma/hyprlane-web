---
import Layout from '../layouts/Layout.astro';
import Lane from '../components/Lane.astro';

const base = import.meta.env.BASE_URL;
---

<Layout title="Home">
  <!-- Hero -->
  <section class="min-h-[85vh] flex flex-col items-center justify-center text-center px-6">
    <h1 class="font-display text-5xl sm:text-6xl md:text-7xl font-semibold tracking-tight leading-tight max-w-3xl">
      Verify once.<br />Pass everywhere.
    </h1>
    <p class="mt-6 text-lg text-text-secondary max-w-xl">
      One-time verification, instantly trusted across every server running Hyprlane.
      No repeated gates, no waiting periods.
    </p>

    <div class="mt-12 w-full max-w-lg">
      <Lane />
    </div>

    <div class="mt-10 flex items-center gap-4">
      <a href="https://discord.com/api/oauth2/authorize?client_id=1524437831823523850&permissions=268435456&scope=bot%20applications.commands" target="_blank" class="btn-primary">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/></svg>
        Add to Discord
      </a>
      <a href="https://github.com/SabeeirSharrma/hyprlane" class="btn-ghost">View on GitHub</a>
    </div>
  </section>

  <!-- How it works -->
  <section class="max-w-[1120px] mx-auto px-6 py-24">
    <h2 class="font-display text-3xl font-semibold tracking-tight mb-12">How it works</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-8">
      <div class="flex flex-col gap-3">
        <span class="text-accent font-mono text-sm">01</span>
        <h3 class="font-display text-lg font-medium">Join a server</h3>
        <p class="text-sm text-text-secondary">Join any Discord server running Hyprlane.</p>
      </div>
      <div class="flex flex-col gap-3">
        <span class="text-accent font-mono text-sm">02</span>
        <h3 class="font-display text-lg font-medium">Click the link</h3>
        <p class="text-sm text-text-secondary">Open the verification link the bot sends you.</p>
      </div>
      <div class="flex flex-col gap-3">
        <span class="text-accent font-mono text-sm">03</span>
        <h3 class="font-display text-lg font-medium">Verify</h3>
        <p class="text-sm text-text-secondary">Log in with Discord and complete the challenge.</p>
      </div>
      <div class="flex flex-col gap-3">
        <span class="text-accent font-mono text-sm">04</span>
        <h3 class="font-display text-lg font-medium">Cleared</h3>
        <p class="text-sm text-text-secondary">Instantly verified in every server with Hyprlane.</p>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="max-w-[1120px] mx-auto px-6 py-24 border-t border-border-subtle">
    <h2 class="font-display text-3xl font-semibold tracking-tight mb-4">Features</h2>
    <p class="text-text-secondary mb-12 max-w-xl">Everything you need to keep your server safe, with premium options for power users.</p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- Free features -->
      <div class="card">
        <div class="w-10 h-10 rounded-lg bg-success/15 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-success" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>
        </div>
        <h3 class="font-display font-semibold mb-2">Cross-Server Identity</h3>
        <p class="text-sm text-text-secondary">Verify once, recognized everywhere. No repeated gates.</p>
      </div>

      <div class="card">
        <div class="w-10 h-10 rounded-lg bg-success/15 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-success" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h3 class="font-display font-semibold mb-2">Disposable Email Detection</h3>
        <p class="text-sm text-text-secondary">Block throwaway accounts at the door.</p>
      </div>

      <div class="card">
        <div class="w-10 h-10 rounded-lg bg-success/15 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-success" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><polyline points="17 11 19 13 23 9"/></svg>
        </div>
        <h3 class="font-display font-semibold mb-2">Moderator Review</h3>
        <p class="text-sm text-text-secondary">Require manual approval before granting access.</p>
      </div>

      <div class="card">
        <div class="w-10 h-10 rounded-lg bg-success/15 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-success" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h3 class="font-display font-semibold mb-2">Re-Verification</h3>
        <p class="text-sm text-text-secondary">Require challenge on every join for high-risk servers.</p>
      </div>

      <!-- Paid features -->
      <div class="card relative overflow-hidden">
        <div class="absolute top-3 right-3">
          <span class="pill pill-accent text-xs">PRO</span>
        </div>
        <div class="w-10 h-10 rounded-lg bg-accent/15 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
        </div>
        <h3 class="font-display font-semibold mb-2">Booster Bypass</h3>
        <p class="text-sm text-text-secondary">Skip verification for server boosters automatically.</p>
      </div>

      <div class="card relative overflow-hidden">
        <div class="absolute top-3 right-3">
          <span class="pill pill-accent text-xs">PRO</span>
        </div>
        <div class="w-10 h-10 rounded-lg bg-accent/15 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        </div>
        <h3 class="font-display font-semibold mb-2">Raid Protection</h3>
        <p class="text-sm text-text-secondary">Monitor join rate and lock down on spikes.</p>
      </div>

      <div class="card relative overflow-hidden">
        <div class="absolute top-3 right-3">
          <span class="pill pill-accent text-xs">PRO</span>
        </div>
        <div class="w-10 h-10 rounded-lg bg-accent/15 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
        </div>
        <h3 class="font-display font-semibold mb-2">Audit Export</h3>
        <p class="text-sm text-text-secondary">Export verification events to your own audit trail.</p>
      </div>

      <div class="card relative overflow-hidden">
        <div class="absolute top-3 right-3">
          <span class="pill pill-accent text-xs">PRO</span>
        </div>
        <div class="w-10 h-10 rounded-lg bg-accent/15 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <h3 class="font-display font-semibold mb-2">Custom Timeout</h3>
        <p class="text-sm text-text-secondary">Override verification link expiry time.</p>
      </div>

      <div class="card relative overflow-hidden">
        <div class="absolute top-3 right-3">
          <span class="pill pill-accent text-xs">PRO</span>
        </div>
        <div class="w-10 h-10 rounded-lg bg-accent/15 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
        </div>
        <h3 class="font-display font-semibold mb-2">Vanity URL</h3>
        <p class="text-sm text-text-secondary">Custom slug on hyprlane.qd.je/s/your-server.</p>
      </div>

      <div class="card relative overflow-hidden">
        <div class="absolute top-3 right-3">
          <span class="pill pill-accent text-xs">PRO</span>
        </div>
        <div class="w-10 h-10 rounded-lg bg-accent/15 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="4"/><line x1="1.05" y1="12" x2="7" y2="12"/><line x1="17.01" y1="12" x2="22.96" y2="12"/></svg>
        </div>
        <h3 class="font-display font-semibold mb-2">Custom Domain</h3>
        <p class="text-sm text-text-secondary">Use your own domain for verification links.</p>
      </div>
    </div>
  </section>

  <!-- Built in the open -->
  <section class="max-w-[1120px] mx-auto px-6 py-24 border-t border-border-subtle">
    <h2 class="font-display text-3xl font-semibold tracking-tight mb-4">Built in the open</h2>
    <p class="text-text-secondary mb-12 max-w-xl">Three public repos. Every line of code auditable.</p>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
      <a href="https://github.com/SabeeirSharrma/hyprlane" class="card group hover:border-accent transition-colors">
        <h3 class="font-display text-lg font-medium group-hover:text-accent transition-colors">hyprlane</h3>
        <p class="mt-2 text-sm text-text-secondary">Discord bot client. Join events, DMs, role assignment.</p>
        <span class="mt-4 inline-block text-xs text-text-muted font-mono">Node.js · discord.js</span>
      </a>
      <a href="https://github.com/SabeeirSharrma/hyprlane-api" class="card group hover:border-accent transition-colors">
        <h3 class="font-display text-lg font-medium group-hover:text-accent transition-colors">hyprlane-api</h3>
        <p class="mt-2 text-sm text-text-secondary">Backend API. Auth, verification, Supabase.</p>
        <span class="mt-4 inline-block text-xs text-text-muted font-mono">Cloudflare Workers · Hono</span>
      </a>
      <a href="https://github.com/SabeeirSharrma/hyprlane-web" class="card group hover:border-accent transition-colors">
        <h3 class="font-display text-lg font-medium group-hover:text-accent transition-colors">hyprlane-web</h3>
        <p class="mt-2 text-sm text-text-secondary">Dashboard and verification pages. Static, auditable.</p>
        <span class="mt-4 inline-block text-xs text-text-muted font-mono">Astro · Tailwind</span>
      </a>
    </div>
  </section>
</Layout>
