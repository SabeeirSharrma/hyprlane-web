---
import Layout from '../../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="Dashboard" description="Manage your server's Hyprlane verification">
  <div class="min-h-[80vh] flex items-center justify-center px-6">
    <div class="text-center max-w-md">
      <div class="w-16 h-16 rounded-2xl bg-accent/15 flex items-center justify-center mx-auto mb-6">
        <svg class="w-8 h-8 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"/>
          <polyline points="12 6 12 12 16 14"/>
        </svg>
      </div>
      <h1 class="font-display text-3xl font-semibold tracking-tight mb-4">Dashboard Coming Soon</h1>
      <p class="text-text-secondary mb-8">
        The server dashboard is under construction. Verification is fully operational — the bot is live and working.
      </p>
      <div class="flex items-center justify-center gap-4">
        <a href={`${base}verify/`} class="btn-primary">Verify Now</a>
        <a href="https://discord.com/api/oauth2/authorize?client_id=1524437831823523850&permissions=268435456&scope=bot%20applications.commands" target="_blank" class="btn-ghost">Add Bot to Server</a>
      </div>
    </div>
  </div>
</Layout>
