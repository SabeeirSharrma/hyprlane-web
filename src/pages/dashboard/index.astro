---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Dashboard" description="Manage your server's Hyprlane verification">
  <div class="flex min-h-screen">
    <aside id="sidebar" class="w-56 bg-bg-surface border-r border-border-subtle fixed h-full flex flex-col hidden">
      <div class="p-4 border-b border-border-subtle">
        <a href={`${import.meta.env.BASE_URL}`} class="font-display text-lg font-semibold text-text-primary hover:text-accent transition-colors">Hyprlane</a>
      </div>
      <nav id="sidebar-nav" class="flex-1 p-3 flex flex-col gap-1"></nav>
    </aside>

    <main id="main" class="flex-1 p-8">
      <div id="view-login" class="flex items-center justify-center min-h-[70vh]">
        <div class="text-center">
          <h1 class="font-display text-3xl font-semibold mb-4">Server Dashboard</h1>
          <p class="text-text-secondary mb-8">Log in with Discord to manage your server.</p>
          <button id="login-btn" class="btn-primary">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/></svg>
            Login with Discord
          </button>
        </div>
      </div>

      <div id="view-guilds" class="hidden">
        <h1 class="font-display text-3xl font-semibold mb-2">Select a server</h1>
        <p class="text-text-secondary mb-8">Choose which server to manage.</p>
        <div id="guild-list" class="flex flex-col gap-3 max-w-lg"></div>
      </div>

      <div id="view-overview" class="hidden">
        <h1 class="font-display text-2xl font-semibold tracking-tight mb-6">Overview</h1>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-8">
          <div class="card"><p class="text-sm text-text-secondary mb-1">Verified users</p><p id="stat-verified" class="text-3xl font-display font-semibold text-accent">0</p></div>
          <div class="card"><p class="text-sm text-text-secondary mb-1">Flagged accounts</p><p id="stat-flagged" class="text-3xl font-display font-semibold text-danger">0</p></div>
          <div class="card"><p class="text-sm text-text-secondary mb-1">Features</p><p id="stat-features" class="text-lg font-medium text-text-primary">—</p></div>
        </div>
      </div>

      <div id="view-members" class="hidden">
        <h1 class="font-display text-2xl font-semibold tracking-tight mb-6">Verified Members</h1>
        <input type="text" id="member-search" placeholder="Search by Discord ID..." class="input max-w-sm mb-6" />
        <div id="members-empty" class="hidden text-text-secondary py-12 text-center">No one's verified here yet.</div>
        <div id="members-list" class="hidden flex flex-col"></div>
      </div>

      <div id="view-settings" class="hidden">
        <h1 class="font-display text-2xl font-semibold tracking-tight mb-6">Settings</h1>
        <form id="settings-form" class="max-w-xl flex flex-col gap-6">
          <div><label class="block text-sm font-medium text-text-secondary mb-2">Verified Role ID</label><input type="text" id="cfg-role" class="input" placeholder="e.g. 1234567890123456789" /></div>
          <div><label class="block text-sm font-medium text-text-secondary mb-2">Log Channel ID</label><input type="text" id="cfg-log" class="input" placeholder="Optional" /></div>
          <div><label class="block text-sm font-medium text-text-secondary mb-2">Mod Role ID</label><input type="text" id="cfg-mod" class="input" placeholder="Optional" /></div>
          <div>
            <label class="block text-sm font-medium text-text-secondary mb-3">Features</label>
            <div class="flex flex-col gap-3">
              <label class="flex items-center gap-3 cursor-pointer"><input type="checkbox" id="feat-challenge" class="w-4 h-4 accent-accent rounded" /><span class="text-sm">Require challenge for all joins</span></label>
              <label class="flex items-center gap-3 cursor-pointer"><input type="checkbox" id="feat-phone" class="w-4 h-4 accent-accent rounded" /><span class="text-sm">Phone number required</span></label>
              <label class="flex items-center gap-3 cursor-pointer"><input type="checkbox" id="feat-modreview" class="w-4 h-4 accent-accent rounded" /><span class="text-sm">Moderator review required</span></label>
            </div>
          </div>
          <div id="save-ok" class="hidden text-sm text-success">Saved.</div>
          <button type="submit" class="btn-primary self-start">Save settings</button>
        </form>
      </div>
    </main>
  </div>

  <script>
    const API = 'https://hyprlane-api.sabplay-idk.workers.dev';
    const CID = '1524437831823523850';
    const base = import.meta.env.BASE_URL;
    let session = sessionStorage.getItem('session_token');
    let guildId: string | null = null;
    let allMembers: any[] = [];

    function showView(name: string) {
      document.querySelectorAll('[id^="view-"]').forEach(el => el.classList.add('hidden'));
      document.getElementById(`view-${name}`)?.classList.remove('hidden');
    }

    function buildNav(gid: string) {
      const nav = document.getElementById('sidebar-nav')!;
      const items = [
        { id: 'overview', label: 'Overview', sub: '' },
        { id: 'members', label: 'Members', sub: 'members' },
        { id: 'settings', label: 'Settings', sub: 'settings' },
      ];
      const currentHash = window.location.hash.replace('#', '');
      nav.innerHTML = items.map(v => {
        const active = v.sub === currentHash || (!v.sub && !currentHash);
        return `<a href="#${v.sub}" data-view="${v.id}" class="nav-link px-3 py-2 rounded text-sm transition-colors ${active ? 'bg-accent/10 text-accent' : 'text-text-secondary hover:text-text-primary hover:bg-bg-surface-raised'}">${v.label}</a>`;
      }).join('');
      nav.querySelectorAll('.nav-link').forEach(link => {
        link.addEventListener('click', (e) => {
          e.preventDefault();
          const view = (e.currentTarget as HTMLElement).dataset.view!;
          const sub = (e.currentTarget as HTMLAnchorElement).hash.replace('#', '');
          window.history.replaceState({}, '', `${base}dashboard/${gid}/${sub ? sub + '/' : ''}`);
          activateView(view);
        });
      });
    }

    function activateView(view: string) {
      showView(view);
      document.querySelectorAll('.nav-link').forEach(el => {
        const isActive = el.getAttribute('data-view') === view;
        el.classList.toggle('bg-accent/10', isActive);
        el.classList.toggle('text-accent', isActive);
        el.classList.toggle('text-text-secondary', !isActive);
      });
      if (view === 'overview') loadOverview();
      if (view === 'members') loadMembers();
      if (view === 'settings') loadSettings();
    }

    function parseUrl() {
      const path = window.location.pathname.replace(base, '');
      const parts = path.split('/').filter(Boolean);
      if (parts.length >= 2 && parts[0] === 'dashboard') {
        guildId = parts[1];
        document.getElementById('sidebar')!.classList.remove('hidden');
        document.getElementById('main')!.classList.add('ml-56');
        buildNav(guildId);
        const sub = parts[2] || '';
        return sub === 'members' ? 'members' : sub === 'settings' ? 'settings' : 'overview';
      }
      return null;
    }

    const initial = parseUrl();
    if (initial && session) { showView('overview'); activateView(initial); }
    else if (session) { showView('guilds'); loadGuilds(); }
    else { showView('login'); }

    const code = new URLSearchParams(window.location.search).get('code');
    if (code) handleCallback(code);

    document.getElementById('login-btn')?.addEventListener('click', () => {
      const redir = `${window.location.origin}${base}dashboard/`;
      window.location.href = `https://discord.com/api/oauth2/authorize?client_id=${CID}&redirect_uri=${encodeURIComponent(redir)}&response_type=code&scope=identify+guilds`;
    });

    async function handleCallback(code: string) {
      try {
        const res = await fetch(`${API}/auth/discord/callback`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ code, redirect_uri: `${window.location.origin}${base}dashboard/` }),
        });
        const data = await res.json();
        if (data.session_token) {
          sessionStorage.setItem('session_token', data.session_token);
          session = data.session_token;
          window.history.replaceState({}, '', `${base}dashboard/`);
          showView('guilds'); loadGuilds();
        }
      } catch { showView('login'); }
    }

    async function loadGuilds() {
      if (!session) return;
      try {
        const res = await fetch(`${API}/dashboard/guilds`, { headers: { Authorization: `Bearer ${session}` } });
        const guilds = await res.json();
        document.getElementById('guild-list')!.innerHTML = guilds.map((g: any) => `
          <a href="${base}dashboard/${g.id}/" class="card flex items-center gap-4 hover:border-accent transition-colors">
            ${g.icon ? `<img src="https://cdn.discordapp.com/icons/${g.id}/${g.icon}.png" class="w-10 h-10 rounded-full" alt="" />` : `<div class="w-10 h-10 rounded-full bg-bg-surface-raised flex items-center justify-center text-text-muted text-sm font-medium">${g.name.charAt(0)}</div>`}
            <span class="font-medium">${g.name}</span>
          </a>
        `).join('');
      } catch { showView('login'); }
    }

    async function loadOverview() {
      if (!session || !guildId) return;
      try {
        const [stats, config] = await Promise.all([
          fetch(`${API}/dashboard/guilds/${guildId}/stats`, { headers: { Authorization: `Bearer ${session}` } }).then(r => r.json()),
          fetch(`${API}/dashboard/guilds/${guildId}/config`, { headers: { Authorization: `Bearer ${session}` } }).then(r => r.json()),
        ]);
        document.getElementById('stat-verified')!.textContent = String(stats.verified_count ?? 0);
        document.getElementById('stat-flagged')!.textContent = String(stats.flagged_count ?? 0);
        const f = config.enrolled_features || [];
        document.getElementById('stat-features')!.textContent = f.length ? f.join(', ') : 'Default';
      } catch {}
    }

    async function loadMembers() {
      if (!session || !guildId) return;
      try {
        const res = await fetch(`${API}/dashboard/guilds/${guildId}/verified-members`, { headers: { Authorization: `Bearer ${session}` } });
        allMembers = await res.json();
        renderMembers(allMembers);
      } catch {}
    }

    function renderMembers(members: any[]) {
      const empty = document.getElementById('members-empty')!;
      const list = document.getElementById('members-list')!;
      if (!members.length) { empty.classList.remove('hidden'); list.classList.add('hidden'); return; }
      empty.classList.add('hidden'); list.classList.remove('hidden');
      list.innerHTML = members.map(m => `
        <div class="table-row flex items-center justify-between py-3 px-4">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-bg-surface-raised flex items-center justify-center text-text-muted text-xs font-mono">${m.discord_id.slice(-4)}</div>
            <div><p class="text-sm font-medium">${m.discord_id}</p><p class="text-xs text-text-muted font-mono">${m.verified_at ? new Date(m.verified_at).toLocaleDateString() : '—'}</p></div>
          </div>
          <div class="flex items-center gap-3"><span class="pill pill-success">verified</span>${m.phone_linked ? '<span class="pill pill-success">phone</span>' : ''}</div>
        </div>
      `).join('');
    }

    document.getElementById('member-search')?.addEventListener('input', (e) => {
      const q = (e.target as HTMLInputElement).value.toLowerCase();
      renderMembers(allMembers.filter(m => m.discord_id.includes(q)));
    });

    async function loadSettings() {
      if (!session || !guildId) return;
      try {
        const c = await fetch(`${API}/dashboard/guilds/${guildId}/config`, { headers: { Authorization: `Bearer ${session}` } }).then(r => r.json());
        (document.getElementById('cfg-role') as HTMLInputElement).value = c.verified_role_id || '';
        (document.getElementById('cfg-log') as HTMLInputElement).value = c.log_channel_id || '';
        (document.getElementById('cfg-mod') as HTMLInputElement).value = c.mod_role_id || '';
        const f = c.enrolled_features || [];
        (document.getElementById('feat-challenge') as HTMLInputElement).checked = f.includes('require_challenge');
        (document.getElementById('feat-phone') as HTMLInputElement).checked = f.includes('phone_required');
        (document.getElementById('feat-modreview') as HTMLInputElement).checked = f.includes('mod_review');
      } catch {}
    }

    document.getElementById('settings-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const f: string[] = [];
      if ((document.getElementById('feat-challenge') as HTMLInputElement).checked) f.push('require_challenge');
      if ((document.getElementById('feat-phone') as HTMLInputElement).checked) f.push('phone_required');
      if ((document.getElementById('feat-modreview') as HTMLInputElement).checked) f.push('mod_review');
      await fetch(`${API}/dashboard/guilds/${guildId}/config`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${session}` },
        body: JSON.stringify({
          verified_role_id: (document.getElementById('cfg-role') as HTMLInputElement).value,
          log_channel_id: (document.getElementById('cfg-log') as HTMLInputElement).value || null,
          mod_role_id: (document.getElementById('cfg-mod') as HTMLInputElement).value || null,
          enrolled_features: f,
        }),
      });
      const ok = document.getElementById('save-ok')!;
      ok.classList.remove('hidden');
      setTimeout(() => ok.classList.add('hidden'), 2000);
    });
  </script>
</Layout>
