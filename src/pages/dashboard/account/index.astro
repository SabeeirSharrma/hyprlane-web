---
import Layout from '../../../layouts/Layout.astro';
---

<Layout title="Account" description="Manage your Hyprlane account">
  <div class="min-h-[80vh] flex items-start justify-center px-6 pt-24">
    <div class="w-full max-w-xl flex flex-col gap-6">
      <h1 class="font-display text-3xl font-semibold tracking-tight">Account</h1>

      <div class="card">
        <p class="text-sm text-text-secondary mb-1">Logged in as</p>
        <p id="acct-username" class="text-lg font-medium">—</p>
        <p id="acct-discord-id" class="text-xs text-text-muted font-mono mt-1">—</p>
      </div>

      <div class="card">
        <h3 class="font-medium mb-3">Link phone number</h3>
        <p class="text-sm text-text-secondary mb-4">Required by some servers. Your number is stored as a salted hash — never in plain text.</p>
        <div id="phone-form" class="flex flex-col gap-3">
          <input type="tel" id="phone-input" placeholder="+1234567890" class="input" />
          <button id="phone-send-btn" class="btn-primary self-start">Send OTP</button>
        </div>
        <div id="otp-form" class="hidden flex-col gap-3 mt-3">
          <input type="text" id="otp-input" placeholder="Enter code" class="input" maxlength="6" />
          <button id="otp-confirm-btn" class="btn-primary self-start">Confirm</button>
        </div>
        <p id="phone-status" class="text-sm mt-2 hidden"></p>
      </div>

      <button id="logout-btn" class="btn-ghost self-start text-danger hover:text-danger">Log out</button>
    </div>
  </div>

  <script>
    import { createClient } from '@supabase/supabase-js';

    const API = 'https://hyprlane-api.sabplay-idk.workers.dev';
    const base = import.meta.env.BASE_URL;
    const supabaseUrl = 'https://reieovanxlrqgdqnsyfq.supabase.co';
    const supabaseAnonKey = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InJlaWVvdmFueGxycWdkcW5zeWZxIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODM3NzExMzgsImV4cCI6MjA5OTM0NzEzOH0.bOgC3L-z21lssiTgiPDzEMI9LiLhQJRTzczmkDnGGJY';
    const supabase = createClient(supabaseUrl, supabaseAnonKey, {
      auth: { flowType: 'implicit' },
    });

    let session: any = null;

    function authHeaders() {
      return {
        Authorization: `Bearer ${session?.access_token}`,
        'X-Discord-Token': session?.provider_token || '',
      };
    }

    // Check session
    supabase.auth.getSession().then(({ data: { session: s } }) => {
      if (!s) {
        window.location.href = `${base}dashboard/`;
        return;
      }
      session = s;
      loadAccount();
    });

    supabase.auth.onAuthStateChange((event, s) => {
      if (event === 'SIGNED_OUT') {
        window.location.href = `${base}dashboard/`;
      }
    });

    function loadAccount() {
      if (!session) return;
      const meta = session.user?.user_metadata || {};
      document.getElementById('acct-username').textContent = meta.full_name || meta.custom_claims?.global_name || session.user?.email || '—';
      document.getElementById('acct-discord-id').textContent = meta.provider_id ? `ID: ${meta.provider_id}` : '—';
    }

    document.getElementById('logout-btn')?.addEventListener('click', async () => {
      await supabase.auth.signOut();
    });

    // --- Phone linking ---
    let pendingPhone = '';

    document.getElementById('phone-send-btn')?.addEventListener('click', async () => {
      const phone = (document.getElementById('phone-input') as HTMLInputElement).value.trim();
      if (!phone || !phone.startsWith('+')) {
        showPhoneStatus('Use E.164 format (e.g. +1234567890)', 'danger');
        return;
      }
      pendingPhone = phone;
      const meta = session.user?.user_metadata || {};
      const discordId = meta.provider_id;
      if (!discordId) { showPhoneStatus('Not logged in', 'danger'); return; }

      try {
        const res = await fetch(`${API}/verify/phone/${discordId}/otp`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', ...authHeaders() },
          body: JSON.stringify({ phone }),
        });
        const data = await res.json();
        if (data.ok) {
          document.getElementById('phone-form')?.classList.add('hidden');
          document.getElementById('otp-form')?.classList.remove('hidden');
          showPhoneStatus('Code sent. Check your messages.', 'success');
        } else {
          showPhoneStatus(data.error || 'Failed to send code', 'danger');
        }
      } catch {
        showPhoneStatus('Could not reach server', 'danger');
      }
    });

    document.getElementById('otp-confirm-btn')?.addEventListener('click', async () => {
      const otp = (document.getElementById('otp-input') as HTMLInputElement).value.trim();
      if (!otp || otp.length < 4) {
        showPhoneStatus('Enter the code', 'danger');
        return;
      }
      const meta = session.user?.user_metadata || {};
      const discordId = meta.provider_id;

      try {
        const res = await fetch(`${API}/verify/phone/${discordId}/confirm`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', ...authHeaders() },
          body: JSON.stringify({ phone: pendingPhone, otp }),
        });
        const data = await res.json();
        if (data.ok) {
          showPhoneStatus('Phone linked!', 'success');
          document.getElementById('otp-form')?.classList.add('hidden');
          document.getElementById('phone-form')?.classList.add('hidden');
        } else {
          showPhoneStatus(data.error || 'Verification failed', 'danger');
        }
      } catch {
        showPhoneStatus('Could not reach server', 'danger');
      }
    });

    function showPhoneStatus(msg: string, type: 'success' | 'danger') {
      const el = document.getElementById('phone-status')!;
      el.textContent = msg;
      el.className = `text-sm mt-2 ${type === 'success' ? 'text-success' : 'text-danger'}`;
      el.classList.remove('hidden');
    }
  </script>
</Layout>
