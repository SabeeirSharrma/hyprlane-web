---
interface Props {
  class?: string;
}

const className = Astro.props.class || '';
---

<div class={`relative h-px bg-border-subtle w-full ${className}`}>
  <div class="lane-fill absolute inset-y-0 left-0 bg-accent" style="width: 0%;"></div>
  <div class="lane-dot absolute top-1/2 -translate-y-1/2 w-2 h-2 rounded-full bg-accent shadow-[0_0_8px_var(--color-accent)]" style="left: 0%;"></div>
  <div class="lane-tick absolute top-1/2 -translate-y-1/2 w-0.5 h-3 bg-accent rounded-full opacity-0" style="left: 50%;"></div>
</div>

<style>
  .lane-dot {
    animation: lane-travel 2s ease-in-out forwards;
    animation-delay: 0.3s;
    opacity: 0;
  }

  .lane-fill {
    animation: lane-fill 2s ease-in-out forwards;
    animation-delay: 0.3s;
  }

  .lane-tick {
    animation: lane-tick-glow 2s ease-in-out forwards;
    animation-delay: 1.2s;
  }

  @keyframes lane-travel {
    0% { left: 0%; opacity: 1; }
    45% { left: 48%; opacity: 1; }
    55% { left: 52%; opacity: 1; }
    100% { left: 100%; opacity: 0; }
  }

  @keyframes lane-fill {
    0% { width: 0%; }
    50% { width: 50%; }
    100% { width: 100%; }
  }

  @keyframes lane-tick-glow {
    0%, 40% { opacity: 0; box-shadow: none; }
    50% { opacity: 1; box-shadow: 0 0 12px var(--color-accent); }
    100% { opacity: 1; box-shadow: 0 0 8px var(--color-accent); }
  }

  @media (prefers-reduced-motion: reduce) {
    .lane-dot, .lane-fill, .lane-tick {
      animation: none !important;
    }
    .lane-fill { width: 100% !important; }
    .lane-dot { left: 100% !important; opacity: 0 !important; }
    .lane-tick { opacity: 1 !important; }
  }
</style>
